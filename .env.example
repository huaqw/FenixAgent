# Required: legacy global API key for acp-link / worker JWT signing.
# Multiple keys can be separated by commas, the first key is used for JWT signing.
RCS_API_KEYS=replace-with-a-long-random-token

# Recommended: public base URL of the RCS server.
# Used by server logs, spawned acp-link instances, and better-auth fallback.
RCS_BASE_URL=http://localhost:3000

# Optional: explicit Better Auth URL.
# If unset, the server falls back to BETTER_AUTH_URL -> RCS_BASE_URL -> http://localhost:${RCS_PORT}.
# BETTER_AUTH_URL=http://localhost:3000

# Optional: server listen address.
RCS_HOST=0.0.0.0
RCS_PORT=3000

# Required: PostgreSQL connection string.
DATABASE_URL=postgres://rcs:rcs@localhost:5432/rcs

# Optional: build/runtime version shown by /health.
# RCS_VERSION=0.1.0

# Optional: long-poll timeout in seconds.
# RCS_POLL_TIMEOUT=8

# Optional: heartbeat interval in seconds.
# RCS_HEARTBEAT_INTERVAL=20

# Optional: Bun WebSocket idle timeout in seconds.
# RCS_WS_IDLE_TIMEOUT=255

# Optional: application keep_alive interval in seconds.
# RCS_WS_KEEPALIVE_INTERVAL=20

# Optional: environment/session disconnect timeout in seconds.
# RCS_DISCONNECT_TIMEOUT=120

# Optional: worker JWT expiration time in seconds.
# RCS_JWT_EXPIRES_IN=3600

# Optional: Knowledge Provider configuration for RCS.
# RCS_KNOWLEDGE_PROVIDER=openviking
# RCS_KNOWLEDGE_BASE_URL=http://localhost:1933
# RCS_KNOWLEDGE_API_KEY=<你的 openviking root_api_key>

# Optional: Hermes Gateway WebSocket address for cross-platform messaging.
# If set, RCS will auto-connect to Hermes on startup.
# HERMES_URL=ws://127.0.0.1:8642/messaging

# Optional: Comma-separated list of platforms to subscribe to (default: all).
# HERMES_PLATFORMS=feishu,telegram

# Optional: S3-compatible object storage (RustFS / MinIO / AWS S3).
# RCS_S3_ENABLED=false
# RCS_S3_ENDPOINT=http://localhost:9000
# RCS_S3_REGION=us-east-1
# RCS_S3_ACCESS_KEY=rustfsadmin
# RCS_S3_SECRET_KEY=rustfsadmin@123
# RCS_S3_BUCKET_SESSIONS=rcs-sessions
# RCS_S3_BUCKET_ASSETS=rcs-assets
# RCS_S3_PRESIGN_EXPIRES=3600
# RCS_S3_PRESIGN_UPLOAD_EXPIRES=600
